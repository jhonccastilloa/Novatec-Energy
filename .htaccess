Options -Indexes +FollowSymLinks
DirectoryIndex index.php

RewriteEngine On

RewriteCond %{HTTP_HOST} ^www\.novatecenergy\.pe$ [NC]
RewriteRule ^ https://novatecenergy.pe%{REQUEST_URI} [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^novatecenergy\.pe$ [NC]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://novatecenergy.pe%{REQUEST_URI} [R=301,L,NE]

RewriteRule ^robots\.txt$ robots.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]

RewriteRule ^(config|includes|node_modules)/ - [F,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^producto/([a-z0-9]+(?:-[a-z0-9]+)*)-([0-9]+)$ producto.php?slug=$1&id=$2 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^productos/([a-z0-9]+(?:-[a-z0-9]+)*)/([a-z0-9]+(?:-[a-z0-9]+)*)$ productos.php?category_slug=$1&subcategory_slug=$2 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^productos/([a-z0-9]+(?:-[a-z0-9]+)*)$ productos.php?category_slug=$1 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^productos/([a-z0-9]+(?:-[a-z0-9]+)*)_([0-9]+)$ productos.php?categoria=$2&nombre=$1 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|webp|gif|svg|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
